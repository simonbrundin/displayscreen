# Google Drive Configuration
# Create a service account in Google Cloud Console and share your folder with it

# The folder ID from Google Drive URL
# Example: https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Service account JSON key (copy the entire JSON content)
# Keep this secret - never commit this file
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Slideshow settings
# Time between slide changes in milliseconds (default: 30000 = 30 seconds)
SLIDE_INTERVAL=30000